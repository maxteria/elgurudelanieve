---
import type { ConfidenceScore } from '../lib/types';

interface Props {
  confidence: ConfidenceScore;
}

const { confidence } = Astro.props;

const colorByLabel: Record<
  ConfidenceScore['label'],
  { bg: string; text: string; border: string }
> = {
  Alta: {
    bg: 'bg-emerald-500/10',
    text: 'text-emerald-300/90',
    border: 'border-emerald-500/20',
  },
  Media: {
    bg: 'bg-amber-500/10',
    text: 'text-amber-300/90',
    border: 'border-amber-500/20',
  },
  Baja: {
    bg: 'bg-rose-500/10',
    text: 'text-rose-300/90',
    border: 'border-rose-500/20',
  },
  Incompleta: {
    bg: 'bg-white/[0.04]',
    text: 'text-white/40',
    border: 'border-white/[0.06]',
  },
};

const colors = colorByLabel[confidence.label];
---

<details
  class={`inline-block ${colors.bg} border ${colors.border} rounded-lg px-3 py-2 cursor-pointer`}
  data-confidence-badge
>
  <summary class="list-none flex items-center gap-2">
    <span class="text-[7px] text-white/30 tracking-[0.2em] uppercase font-medium"
      >Confianza</span
    >
    <span class={`text-[13px] font-bold ${colors.text}`}>
      {confidence.label}
    </span>
    <svg
      width="12"
      height="12"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      class="text-white/30 ml-1"
    >
      <circle cx="12" cy="12" r="10"></circle>
      <path d="M12 16v-4M12 8h.01"></path>
    </svg>
  </summary>
  {
    confidence.reasonsFor.length > 0 || confidence.reasonsAgainst.length > 0 ? (
    <div class="mt-2 pt-2 border-t border-white/[0.06]">
    {
      confidence.reasonsFor.length > 0 && (
        <div class="mb-1.5">
          <span class="text-[7px] text-emerald-300/70 tracking-[0.15em] uppercase font-medium block mb-1">
            Señales a favor
          </span>
          <ul class="space-y-0.5">
            {confidence.reasonsFor.map((reason) => (
              <li class="text-[9px] text-white/50 flex items-start gap-1.5">
                <span class="text-emerald-400/70 mt-0.5">+</span>
                <span>{reason}</span>
              </li>
            ))}
          </ul>
        </div>
      )
    }
    {
      confidence.reasonsAgainst.length > 0 && (
        <div class="mb-1.5">
          <span class="text-[7px] text-rose-300/70 tracking-[0.15em] uppercase font-medium block mb-1">
            Razones de la lectura
          </span>
          <ul class="space-y-0.5">
            {confidence.reasonsAgainst.map((reason) => (
              <li class="text-[9px] text-white/50 flex items-start gap-1.5">
                <span class="text-rose-400/70 mt-0.5">−</span>
                <span>{reason}</span>
              </li>
            ))}
          </ul>
        </div>
      )
    }
    <p class="text-[7px] text-white/25 leading-relaxed mt-1.5">
      Índice de consistencia de señales, no probabilidad exacta.
    </p>
  </div>
    ) : null
  }
</details>
