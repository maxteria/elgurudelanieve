---
const { alerts } = Astro.props;
---

<div
  class="bg-surface border border-border-subtle rounded-xl px-4 py-3 shadow-[0_4px_20px_rgba(0,0,0,0.35)]"
  data-period-alerts
>
  <span class="text-[7px] text-text-muted tracking-[0.3em] uppercase font-medium"
    >{alerts.length > 0 ? 'Alertas' : 'Sin alertas relevantes'}</span
  >
  {
    [0, 1].map((i) => {
      const a = alerts[i];
      return (
        <div
          class="mt-2 flex items-start gap-2 px-2.5 py-2 rounded-lg bg-naranja/[0.06] border border-naranja/[0.08]"
          data-period-alert-item
          style={`display:${a ? '' : 'none'}`}
        >
          <span class="text-[10px] mt-0.5 opacity-70">⚠</span>
          <div>
            <span
              class="text-[10px] text-naranja font-medium"
              data-period-alert-msg
            >
              {a?.message || ''}
            </span>
            {a?.level === 'danger' && (
              <span class="text-[8px] text-text-muted block mt-0.5">
                Tomar precauciones.
              </span>
            )}
          </div>
        </div>
      );
    })
  }
  <p
    class="text-[10px] text-text-muted mt-2"
    data-period-alerts-none
    style={`display:${alerts.length === 0 ? '' : 'none'}`}
  >
    Sin alertas relevantes. Viento, precipitación y cota sin condiciones
    críticas para nevada.
  </p>
</div>
