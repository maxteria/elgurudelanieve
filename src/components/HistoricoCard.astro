---
import type { DailyHistoryEntry } from '../lib/supabase/types';

type Props = {
  entry: DailyHistoryEntry;
};

const { entry } = Astro.props as Props;

function formatDate(iso: string): string {
  const d = new Date(iso + 'T12:00:00');
  return d.toLocaleDateString('es-AR', {
    weekday: 'long',
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

const windKmh =
  entry.aic?.wind_speed != null
    ? `${Math.round(entry.aic.wind_speed * 3.6)} km/h`
    : null;

const humidity = entry.aic?.humidity != null ? `${entry.aic.humidity}%` : null;
const swe = entry.swe != null ? `${entry.swe} mm` : null;
---

<div
  class="bg-surface border border-border-subtle rounded-xl p-4 shadow-[0_4px_20px_rgba(0,0,0,0.35)] flex flex-col h-full"
>
  <!-- Date header -->
  <div class="mb-2">
    <h3 class="text-[11px] font-semibold text-text-primary capitalize leading-tight">
      {formatDate(entry.date)}
    </h3>
  </div>

  <!-- Metrics -->
  <div class="space-y-1 mb-1.5">
    <div class="flex items-center justify-between text-[9px]">
      <span class="text-text-muted">Temp</span>
      <span class="text-text-primary font-semibold tabular-nums"
        >{entry.tempMin ?? '--'}° / {entry.tempMax ?? '--'}°</span
      >
    </div>
    <div class="flex items-center justify-between text-[9px]">
      <span class="text-text-muted">Humedad</span>
      <span class="text-text-primary font-semibold tabular-nums"
        >{humidity ?? '--'}</span
      >
    </div>
    <div class="flex items-center justify-between text-[9px]">
      <span class="text-text-muted">Viento</span>
      <span class="text-text-primary font-semibold tabular-nums"
        >{windKmh ?? '--'}</span
      >
    </div>
    <div class="flex items-center justify-between text-[9px]">
      <span class="text-text-muted">SWE (nieve)</span>
      <span class="text-text-primary font-semibold tabular-nums"
        >{swe ?? '--'}</span
      >
    </div>
  </div>

  <!-- Guru message -->
  <div class="mt-auto pt-2.5 border-t border-border-subtle">
    {
      entry.guru?.message ? (
        <p class="text-[10px] text-text-secondary leading-relaxed line-clamp-2">
          {entry.guru.message}
        </p>
      ) : (
        <p class="text-[9px] text-text-faint italic">
          Sin mensaje del Gurú
        </p>
      )
    }
  </div>
</div>
