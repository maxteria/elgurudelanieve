---
import type { SignalSummary, SourceStatus } from '../lib/types';

interface Props {
  signals: SignalSummary;
  sourceStatus?: SourceStatus;
}

const { signals, sourceStatus } = Astro.props;

const zones = [
  { key: 'village', label: 'Pueblo', altitude: 1647 },
  { key: 'mid', label: 'Centro', altitude: 1846 },
  { key: 'top', label: 'Cumbre', altitude: 2045 },
] as const;

const aicUnavailable = sourceStatus && sourceStatus.aic !== 'ok';

function hasRealData(value: number | null | undefined): boolean {
  return value != null && !Number.isNaN(value);
}

const hasAnyRealData = zones.some((zone) => {
  const data = signals[zone.key];
  if (!data) return false;
  return (
    hasRealData(data.temperature) ||
    hasRealData(data.precipitation) ||
    hasRealData(data.snowfall) ||
    hasRealData(data.freezingLevel) ||
    hasRealData(data.wind) ||
    hasRealData(data.humidity)
  );
});

const fmt = (value: number | null | undefined, unit: string): string => {
  if (!hasRealData(value)) return '—';
  return `${value}${unit}`;
};
---

{
  hasAnyRealData ? (
    <details
      class="bg-[rgba(9,16,22,0.85)] border border-white/[0.06] rounded-xl px-4 py-3 shadow-[0_4px_20px_rgba(0,0,0,0.35)] group"
      data-signal-summary
    >
      <summary class="list-none flex items-center justify-between cursor-pointer">
        <span class="text-[9px] text-hielo/60 tracking-[0.2em] uppercase font-medium">
          ¿Por qué dice esto?
        </span>
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          class="text-white/30 group-open:rotate-180 transition-transform"
        >
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </summary>

      <div class="mt-3 pt-3 border-t border-white/[0.06]">
        <div class="grid grid-cols-3 gap-2">
          {zones.map((zone) => {
            const data = signals[zone.key];
            return (
              <div class="space-y-1.5">
                <div class="text-[8px] text-white/30 tracking-wide uppercase font-medium mb-1">
                  {zone.label}
                  <span class="block text-[7px] text-white/20 normal-case">
                    {zone.altitude} m
                  </span>
                </div>
                <div class="flex justify-between text-[9px]">
                  <span class="text-white/35">Temp</span>
                  <span class="text-white/60 font-medium tabular-nums">
                    {fmt(data?.temperature, '°C')}
                  </span>
                </div>
                <div class="flex justify-between text-[9px]">
                  <span class="text-white/35">Precip</span>
                  <span class="text-white/60 font-medium tabular-nums">
                    {fmt(data?.precipitation, ' mm')}
                  </span>
                </div>
                <div class="flex justify-between text-[9px]">
                  <span class="text-white/35">Nieve</span>
                  <span class="text-white/60 font-medium tabular-nums">
                    {fmt(data?.snowfall, ' cm')}
                  </span>
                </div>
                <div class="flex justify-between text-[9px]">
                  <span class="text-white/35">Cota</span>
                  <span class="text-white/60 font-medium tabular-nums">
                    {fmt(data?.freezingLevel, ' m')}
                  </span>
                </div>
                <div class="flex justify-between text-[9px]">
                  <span class="text-white/35">Viento</span>
                  <span class="text-white/60 font-medium tabular-nums">
                    {fmt(data?.wind, ' km/h')}
                  </span>
                </div>
                <div class="flex justify-between text-[9px]">
                  <span class="text-white/35">Humedad</span>
                  <span class="text-white/60 font-medium tabular-nums">
                    {fmt(data?.humidity, '%')}
                  </span>
                </div>
              </div>
            );
          })}
        </div>

        {aicUnavailable && (
          <p class="text-[8px] text-white/25 mt-3 pt-2 border-t border-white/[0.04]">
            Validación AIC: no disponible.
          </p>
        )}
      </div>
    </details>
  ) : (
    <div class="bg-[rgba(9,16,22,0.85)] border border-white/[0.06] rounded-xl px-4 py-3 shadow-[0_4px_20px_rgba(0,0,0,0.35)]">
      <p class="text-[9px] text-white/40 leading-relaxed">
        Explicación detallada no disponible para esta corrida.
      </p>
    </div>
  )
}
