---
import type { GuruMood, GuruCertainty, GuruSource } from '../../lib/ai/types';

interface Props {
  mood: GuruMood;
  certainty: GuruCertainty;
  message: string;
  tip: string | null;
  source: GuruSource;
  snowLabel?: string;
}

const { mood, certainty, message, tip, source, snowLabel } =
  Astro.props as Props;
const sourceLabel = source === 'ai' ? 'Gurú IA' : 'Gurú local';

const certaintyLabels: Record<string, string> = {
  alta: 'Nivel de certeza: Alto',
  media: 'Nivel de certeza: Medio',
  baja: 'Nivel de certeza: Bajo',
};
const certaintySegments: Record<string, number> = {
  alta: 3,
  media: 2,
  baja: 1,
};
const segments = certaintySegments[certainty] ?? 1;
---

<section
  class="relative flex flex-col items-center pt-4 pb-6"
  data-guru-npc
  data-mood={mood}
>
  <div class="relative mb-[-20px] z-20">
    <img
      src="/emblema.png"
      alt="El Gurú de la Nieve"
      class="w-32 h-32 relative z-10 drop-shadow-[0_0_30px_rgba(168,231,249,0.4)]"
    />
    <div class="absolute inset-0 bg-hielo/10 rounded-full blur-xl z-0"></div>
    <div class="absolute -inset-4 bg-hielo/6 rounded-full blur-3xl z-0"></div>

    <!-- Mood dot (bottom-right of emblem) -->
    <div
      class="absolute -bottom-1 -right-1 w-5 h-5 rounded-full border-2 border-[rgba(9,16,22,0.97)] shadow-[0_0_8px_var(--mood-color)] z-20"
      style="background: var(--mood-color, #94a3b8)"
      data-mood-indicator
    >
    </div>
  </div>

  <div class="relative w-full max-w-lg mt-0">
    <div
      class="absolute -top-3 left-1/2 -translate-x-1/2 w-5 h-5 bg-[rgba(9,16,22,0.97)] border-l border-t border-hielo/20 rotate-45 z-10"
    >
    </div>

    <div
      class="bg-[rgba(9,16,22,0.97)] border border-hielo/20 rounded-2xl px-6 py-5 shadow-[0_8px_50px_rgba(0,0,0,0.6),0_0_40px_rgba(168,231,249,0.1)]"
    >
      <div class="flex items-center justify-center gap-2 mb-3">
        <span
          class="text-[8px] text-hielo/60 tracking-[0.3em] uppercase font-bold"
          >EL GURÚ MIRA LA MONTAÑA</span
        >
      </div>

      {
        snowLabel && (
          <div class="mb-3">
            <span class="inline-block text-[9px] tracking-[0.2em] uppercase font-semibold text-hielo/50 px-3 py-1 rounded-full bg-hielo/[0.05] border border-hielo/10">
              {snowLabel}
            </span>
          </div>
        )
      }

      <!-- Certainty bar -->
      <div class="flex items-center gap-3 mb-3">
        <div class="certainty-bar">
          {
            Array.from({ length: 3 }, (_, i) => (
              <div
                class={`certainty-bar__segment${i < segments ? ' certainty-bar__segment--filled' : ''}`}
              />
            ))
          }
        </div>
        <span
          class="text-[10px] font-medium tracking-wide"
          style="color: var(--mood-color, #94a3b8)"
          data-certainty-label
        >
          {certaintyLabels[certainty] ?? certainty}
        </span>
        <span
          class="certainty-info"
          data-tip="3 barras = certeza alta · 2 = media · 1 = baja"
        >
          <svg
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="16" x2="12" y2="12"></line>
            <line x1="12" y1="8" x2="12.01" y2="8"></line>
          </svg>
        </span>
        <span class="text-[8px] text-white/25 ml-auto tracking-[0.15em]">
          {sourceLabel}
        </span>
      </div>

      <p
        class="text-[15px] font-medium text-white/85 leading-relaxed"
        data-guru-npc-text
      >
        {message}
      </p>

      <!-- Tip section (conditional) -->
      {
        tip && (
          <div class="tip-callout" data-tip-callout>
            <svg
              class="tip-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="10" />
              <line x1="12" y1="16" x2="12" y2="12" />
              <line x1="12" y1="8" x2="12.01" y2="8" />
            </svg>
            <span>{tip}</span>
          </div>
        )
      }
    </div>
  </div>
</section>
