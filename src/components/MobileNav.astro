---
const { activeSection } = Astro.props as {
  activeSection?: 'home' | 'lab' | 'historico' | 'pronostico';
};

const navItems = [
  { key: 'home', label: 'El Gurú', href: '/' },
  { key: 'pronostico', label: 'Pronóstico', href: '/pronostico' },
  { key: 'lab', label: 'El Gurú Lab', href: '/lab' },
  { key: 'historico', label: 'Histórico', href: '/historico' },
];

function isActive(key: string) {
  if (!activeSection) return key === 'home';
  return activeSection === key;
}
---

<div class="md:hidden fixed top-0 left-0 right-0 z-50" role="banner">
  <div class="flex items-center justify-between px-4 h-12 bg-[rgba(9,16,22,0.95)] border-b border-white/[0.08] backdrop-blur-sm">
    <div class="flex items-center gap-2">
      <img src="/emblema.png" alt="El Gurú de la Nieve" class="w-6 h-6" />
      <span class="text-[10px] font-extrabold tracking-[0.15em] text-white/70">EL GURÚ</span>
    </div>
    <button
      id="mobile-menu-btn"
      class="w-9 h-9 flex items-center justify-center rounded-lg text-white/50 hover:text-white/80 transition-colors"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-drawer"
    >
      <svg id="burger-icon" width="18" height="12" viewBox="0 0 18 12" fill="none">
        <path d="M1 1h16M1 6h16M1 11h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <svg id="close-icon" class="hidden" width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <div
    id="mobile-drawer"
    class="hidden fixed inset-0 top-12 bg-[rgba(9,16,22,0.98)] z-40 overflow-y-auto"
    role="dialog"
    aria-modal="true"
    aria-label="Menú de navegación"
  >
    <nav class="px-6 py-6 space-y-1" role="navigation">
      {navItems.map(item => (
        <a
          href={item.href}
          class={`block px-3 py-3 rounded-lg text-[11px] uppercase tracking-[0.15em] font-semibold transition-colors ${
            isActive(item.key)
              ? 'text-hielo bg-hielo/[0.08]'
              : 'text-white/35 hover:text-white/60'
          }`}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="px-6 pt-4 pb-8 space-y-2 border-t border-white/[0.06]">
      <div class="text-[7px] text-white/20 tracking-[0.25em] uppercase">Estación 2026</div>
      <div class="text-[8px] text-white/25 tracking-wide">Open-Meteo · WeatherAPI</div>
    </div>
  </div>

  <div id="drawer-overlay" class="hidden fixed inset-0 top-12 z-30 bg-black/40" aria-hidden="true"></div>
</div>

<script>
  function initMobileNav() {
    const btn = document.getElementById('mobile-menu-btn');
    const drawer = document.getElementById('mobile-drawer');
    const overlay = document.getElementById('drawer-overlay');
    const burgerIcon = document.getElementById('burger-icon');
    const closeIcon = document.getElementById('close-icon');

    if (!btn || !drawer || !overlay || !burgerIcon || !closeIcon) return;

    let isOpen = false;

    function openMenu() {
      isOpen = true;
      drawer.classList.remove('hidden');
      overlay.classList.remove('hidden');
      btn.setAttribute('aria-expanded', 'true');
      burgerIcon.classList.add('hidden');
      closeIcon.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      isOpen = false;
      drawer.classList.add('hidden');
      overlay.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
      burgerIcon.classList.remove('hidden');
      closeIcon.classList.add('hidden');
      document.body.style.overflow = '';
    }

    btn.addEventListener('click', () => {
      if (isOpen) closeMenu(); else openMenu();
    });

    overlay.addEventListener('click', closeMenu);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) closeMenu();
    });

    drawer.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  }

  initMobileNav();
</script>