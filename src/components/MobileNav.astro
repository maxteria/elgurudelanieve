---
const { activeSection } = Astro.props as {
  activeSection?: 'home' | 'lab' | 'historico' | 'pronostico';
  updated?: string;
  source?: string;
};

const navItems = [
  { key: 'home', label: 'El Gurú', href: '/' },
  { key: 'pronostico', label: 'Pronóstico', href: '/pronostico' },
  { key: 'lab', label: 'El Gurú Lab', href: '/lab' },
  { key: 'historico', label: 'Histórico', href: '/historico' },
];

function isActive(key: string) {
  if (!activeSection) return key === 'home';
  return activeSection === key;
}
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-surface-elevated border-b border-subtle backdrop-blur-md"
>
  <div class="flex items-center justify-between h-12 px-4">
    <div class="flex items-center gap-2.5">
      <img
        src="/emblema.png"
        alt="El Gurú de la Nieve"
        class="w-6 h-6 shrink-0"
      />
      <span class="text-[10px] font-extrabold tracking-[0.18em] text-secondary"
        >EL GURÚ</span
      >
      <span
        class="hidden md:inline text-[7px] text-faint tracking-[0.2em] ml-0.5"
        >DE LA NIEVE</span
      >
    </div>

    <nav
      class="hidden md:flex items-center gap-1"
      role="navigation"
      aria-label="Navegación principal"
    >
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class={`text-[9px] uppercase tracking-[0.15em] font-semibold px-2.5 py-1 rounded-md transition-colors ${
              isActive(item.key)
                ? 'text-hielo/90 bg-hielo/[0.08]'
                : 'text-muted hover:text-secondary'
            }`}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <span class="hidden md:block text-[7px] text-faint tracking-[0.2em]"
        >Estación 2026</span
      >
      <button
        id="theme-toggle"
        class="w-8 h-8 flex items-center justify-center rounded-lg text-secondary hover:text-primary transition-colors"
        aria-label="Cambiar tema"
      >
        <svg id="icon-sun" class="hidden w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <svg id="icon-moon" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
      <button
        id="mobile-menu-btn"
        class="md:hidden w-9 h-9 flex items-center justify-center rounded-lg text-secondary hover:text-primary transition-colors"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-drawer"
      >
        <svg
          id="burger-icon"
          width="18"
          height="12"
          viewBox="0 0 18 12"
          fill="none"
        >
          <path
            d="M1 1h16M1 6h16M1 11h16"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"></path>
        </svg>
        <svg
          id="close-icon"
          class="hidden"
          width="14"
          height="14"
          viewBox="0 0 14 14"
          fill="none"
        >
          <path
            d="M1 1l12 12M13 1L1 13"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<div
  id="mobile-drawer"
  class="hidden fixed inset-0 top-12 bg-surface-elevated z-40 overflow-y-auto"
  role="dialog"
  aria-modal="true"
  aria-label="Menú de navegación"
>
  <nav class="px-6 py-6 space-y-1" role="navigation">
    {
      navItems.map((item) => (
        <a
          href={item.href}
          class={`block px-3 py-3 rounded-lg text-[11px] uppercase tracking-[0.15em] font-semibold transition-colors ${
            isActive(item.key)
              ? 'text-hielo bg-hielo/[0.08]'
              : 'text-muted hover:text-secondary'
          }`}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
  <div class="px-6 pt-4 pb-8 space-y-2 border-t border-subtle">
    <div class="text-[7px] text-faint tracking-[0.25em] uppercase">
      Estación 2026
    </div>
    <div class="text-[8px] text-muted tracking-wide">
      Open-Meteo · WeatherAPI
    </div>
  </div>
</div>

<div
  id="drawer-overlay"
  class="hidden fixed inset-0 top-12 z-30 bg-black/50"
  aria-hidden="true"
>
</div>

<script>
  function initMobileNav() {
    var btn = document.getElementById('mobile-menu-btn');
    var drawer = document.getElementById('mobile-drawer');
    var overlay = document.getElementById('drawer-overlay');
    var burgerIcon = document.getElementById('burger-icon');
    var closeIcon = document.getElementById('close-icon');

    if (!btn || !drawer || !overlay || !burgerIcon || !closeIcon) return;

    var isOpen = false;

    function openMenu() {
      isOpen = true;
      drawer.classList.remove('hidden');
      overlay.classList.remove('hidden');
      btn.setAttribute('aria-expanded', 'true');
      burgerIcon.classList.add('hidden');
      closeIcon.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      isOpen = false;
      drawer.classList.add('hidden');
      overlay.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
      burgerIcon.classList.remove('hidden');
      closeIcon.classList.add('hidden');
      document.body.style.overflow = '';
    }

    btn.addEventListener('click', function () {
      if (isOpen) closeMenu();
      else openMenu();
    });

    overlay.addEventListener('click', closeMenu);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && isOpen) closeMenu();
    });

    var links = drawer.querySelectorAll('a');
    for (var i = 0; i < links.length; i++) {
      links[i].addEventListener('click', closeMenu);
    }
  }

  function initThemeToggle() {
    var toggle = document.getElementById('theme-toggle');
    var sunIcon = document.getElementById('icon-sun');
    var moonIcon = document.getElementById('icon-moon');
    if (!toggle || !sunIcon || !moonIcon) return;

    function updateIcon() {
      var isLight = document.documentElement.getAttribute('data-theme') === 'light';
      if (isLight) {
        sunIcon.classList.remove('hidden');
        moonIcon.classList.add('hidden');
      } else {
        sunIcon.classList.add('hidden');
        moonIcon.classList.remove('hidden');
      }
    }

    updateIcon();

    toggle.addEventListener('click', function () {
      var isLight = document.documentElement.getAttribute('data-theme') === 'light';
      if (isLight) {
        document.documentElement.removeAttribute('data-theme');
        localStorage.setItem('theme', 'dark');
      } else {
        document.documentElement.setAttribute('data-theme', 'light');
        localStorage.setItem('theme', 'light');
      }
      updateIcon();
    });
  }

  initMobileNav();
  initThemeToggle();
</script>

