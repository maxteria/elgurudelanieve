---
import type { GuruMood, GuruCertainty, GuruSource } from './ai/types';

interface Props {
  mood: GuruMood;
  certainty: GuruCertainty;
  message: string;
  tip: string | null;
  source: GuruSource;
}

const { mood, certainty, message, tip, source } = Astro.props as Props;
const sourceLabel = source === 'ai' ? 'Gurú AI' : 'Gurú local';

const certaintyLabels: Record<string, string> = {
  alta: 'Alta',
  media: 'Media',
  baja: 'Baja',
};
---

<section
  class="relative overflow-hidden rounded-xl border border-hielo/15 bg-[rgba(9,16,22,0.92)] shadow-[0_8px_40px_rgba(0,0,0,0.5),0_0_30px_rgba(168,231,249,0.06)]"
  data-period-guru-tourist
  data-mood={mood}
>
  <!-- Top glow line -->
  <div
    class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-hielo/40 to-transparent"
  >
  </div>
  <!-- Background glow -->
  <div
    class="absolute -top-12 -left-12 w-48 h-48 bg-hielo/[0.04] rounded-full blur-3xl pointer-events-none"
  >
  </div>

  <div class="relative z-10 px-5 py-4 flex items-start gap-4">
    <!-- Avatar with mood dot -->
    <div class="relative shrink-0">
      <div
        class="w-10 h-10 rounded-full bg-gradient-to-br from-hielo/25 to-hielo/8 border border-hielo/20 flex items-center justify-center shadow-[0_0_16px_rgba(168,231,249,0.1)]"
      >
        <svg
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#a8e7f9"
          stroke-width="1.4"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="10" r="7"></circle>
          <path d="M8 20h8"></path>
          <path d="M9 20c0-2 1.3-3 3-3s3 1 3 3"></path>
          <path d="M12 3v1M9 4.5 10 6M15 4.5 14 6" stroke-width="1.2"></path>
          <circle cx="12" cy="10" r="2" stroke-width="1" opacity="0.5"></circle>
          <path
            d="M10.5 9c.5-.5 1.5-.5 2 0 .5.5.5 1.5 0 2-.5.5-1.5.5-2 0"
            stroke-width="0.8"
            opacity="0.6"></path>
        </svg>
      </div>
      <!-- Mood dot (bottom-right corner of avatar) -->
      <div
        class="absolute -bottom-0.5 -right-0.5 w-3.5 h-3.5 rounded-full border-2 border-[rgba(9,16,22,0.92)] z-10"
        style="background: var(--mood-color, #94a3b8)"
        data-mood-indicator
      ></div>
    </div>

    <!-- Content -->
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1.5">
        <span
          class="text-[9px] text-white/30 tracking-[0.25em] uppercase font-semibold"
          >Lo que dice el Gurú</span
        >
        <span
          class="text-[7px] text-hielo/35 tracking-[0.12em] uppercase border border-hielo/12 rounded-full px-2 py-[2px] bg-hielo/[0.04]"
          >{sourceLabel}</span
        >
        <!-- Certainty text label -->
        <span
          class="text-[7px] tracking-[0.12em] uppercase border rounded-full px-2 py-[2px]"
          style="border-color: color-mix(in srgb, var(--mood-color, #94a3b8) 25%, transparent); background: color-mix(in srgb, var(--mood-color, #94a3b8) 8%, transparent); color: var(--mood-color, #94a3b8)"
          data-certainty-label
        >
          {certaintyLabels[certainty] ?? certainty}
        </span>
        <span
          class="certainty-info"
          data-tip="3 barras = certeza alta · 2 = media · 1 = baja"
        >
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="16" x2="12" y2="12"/>
            <line x1="12" y1="8" x2="12.01" y2="8"/>
          </svg>
        </span>
      </div>
      <p
        class="text-[13px] font-medium text-hielo/80 leading-relaxed"
        data-period-guru-tourist-text
      >
        {message}
      </p>
      <!-- Tip line (conditional) -->
      {
        tip && (
          <div class="flex items-start gap-1.5 mt-2" data-tip-line>
            <svg class="tip-icon mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="16" x2="12" y2="12"/>
              <line x1="12" y1="8" x2="12.01" y2="8"/>
            </svg>
            <span class="text-[11px] text-white/50 leading-relaxed">{tip}</span>
          </div>
        )
      }
    </div>
  </div>
</section>
