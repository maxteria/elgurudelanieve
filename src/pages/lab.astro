---
import '../styles/tailwind.css';
import type { PeriodKey, PeriodInterpretations } from '../lib/types';
import type { DemoSenario } from '../data/demo-scenarios';
import {
  getWeatherData,
  type WeatherMode,
} from '../lib/weather/weather-source';
import { analyzeAllPeriods } from '../lib/period-engine';
import {
  getTodayForecast,
  getTomorrowForecast,
  getSevenDayForecast,
} from '../lib/forecast-periods';
import { isValidScenario } from '../data/demo-scenarios';
import MobileNav from '../components/MobileNav.astro';
import NowCard from '../components/NowCard.astro';
import PowderScore from '../components/PowderScore.astro';
import ZoneCard from '../components/ZoneCard.astro';
import ForecastChart from '../components/ForecastChart.astro';
import SnowWindow from '../components/SnowWindow.astro';
import AlertsPanel from '../components/AlertsPanel.astro';
import GuruSummary from '../components/GuruSummary.astro';
import { generateTouristCopy, type GuruCopyInput } from '../lib/ai/guru-copy';
import type { GuruNpcOutput } from '../lib/ai/types';

const params = Astro.url.searchParams;
const demoParam = params.get('demo');
const activeScenario: DemoSenario | undefined = isValidScenario(demoParam)
  ? demoParam
  : undefined;
const queryMode: WeatherMode | undefined =
  demoParam === '1' || activeScenario ? 'demo' : undefined;
const envMode: WeatherMode | undefined =
  process.env.PUBLIC_WEATHER_MODE === 'demo' ? 'demo' : undefined;
const activeMode: WeatherMode = queryMode ?? envMode ?? 'real';

const { normalized, weatherApi, source } = await getWeatherData({
  mode: activeMode,
  scenario: activeScenario,
});
const firstPeriod: PeriodKey = 'today';
const periods = analyzeAllPeriods(normalized);
const result = periods[firstPeriod];
if (weatherApi) result.weatherApi = weatherApi;
const zoneList = [result.zones.village, result.zones.mid, result.zones.top];
const isDemo = source === 'mock-demo';

const dailySummaries = getSevenDayForecast(normalized.hourly);
const periodKeys: PeriodKey[] = ['today', 'tomorrow', 'sevenDays'];
const touristResults = await Promise.all(
  periodKeys.map(async (key) => {
    const p = periods[key];
    const input: GuruCopyInput = {
      period: key,
      mainAnswer: p.mainAnswer,
      powderScore: p.powderScore,
      bestWindow: p.bestWindow,
      alerts: p.alerts,
      zones: p.zones,
      now: weatherApi ?? undefined,
      nextDays: dailySummaries,
      aicHistory: normalized.aicHistory,
    };
    return generateTouristCopy(input);
  }),
);
const touristData: Record<PeriodKey, GuruNpcOutput> = {} as Record<
  PeriodKey,
  GuruNpcOutput
>;
const touristCopies: Record<PeriodKey, string> = {} as Record<
  PeriodKey,
  string
>;
const touristSources: Record<PeriodKey, string> = {} as Record<
  PeriodKey,
  string
>;
const touristMoods: Record<PeriodKey, string> = {} as Record<PeriodKey, string>;
const touristCertainties: Record<PeriodKey, string> = {} as Record<
  PeriodKey,
  string
>;
const touristTips: Record<PeriodKey, string | null> = {} as Record<
  PeriodKey,
  string | null
>;
periodKeys.forEach((key, i) => {
  const r = touristResults[i];
  touristData[key] = r;
  touristCopies[key] = r.message;
  touristSources[key] = r.source;
  touristMoods[key] = r.mood;
  touristCertainties[key] = r.certainty;
  touristTips[key] = r.tip;
});

const periodDataJson = JSON.stringify({
  periods,
  dailySummaries,
  touristCopies,
  touristSources,
  touristMoods,
  touristCertainties,
  touristTips,
});

function buildZoneHourly(period: PeriodKey) {
  const hourly =
    period === 'today'
      ? getTodayForecast(normalized.hourly)
      : period === 'tomorrow'
        ? getTomorrowForecast(normalized.hourly)
        : normalized.hourly;
  if (hourly.length === 0) return [];
  const midZone = normalized.zones.mid;
  return hourly.map((h) => {
    const zoneOffset =
      (midZone.altitude - normalized.zones.village.altitude) * 0.0065;
    const zoneTemp = Math.round((h.temp - zoneOffset) * 10) / 10;
    return {
      hour: new Date(h.time).getHours(),
      temp: zoneTemp,
      feels_like: h.feelsLike,
      wind: h.wind,
      windDir: h.windDir,
      cloudCover: h.cloudCover,
      windGusts: h.windGusts,
      precip: h.precipitation,
      snow_prob: h.precipitationProbability ?? 0,
      freezing_level: h.freezingLevel,
      humidity: h.humidity,
      snowfall: h.snowfall,
      snowDepth: h.snowDepth,
      weatherCode: h.weatherCode,
      precipitationProbability: h.precipitationProbability ?? 0,
    };
  });
}
const zoneHourlyToday = buildZoneHourly('today');
const zoneHourlyTomorrow = buildZoneHourly('tomorrow');
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>El Gurú Lab | Dashboard técnico de nieve para Caviahue</title>
    <meta
      name="description"
      content="Dashboard técnico de condiciones de nieve para Caviahue. Powder Score, cota, temperatura y mejores ventanas de nieve."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/emblema.png" />
    <meta name="theme-color" content="#a8e7f9" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="text-white min-h-screen antialiased font-premium overflow-x-hidden"
  >
    <MobileNav activeSection="lab" />
    <main class="min-h-screen pt-12 px-4 md:px-8 pb-8">
      {
        isDemo && (
          <div class="absolute top-14 right-4 z-20 flex items-center gap-1 px-2 py-0.5 rounded-full border border-amber-400/20 bg-amber-400/5 text-[7px] tracking-[0.2em] uppercase text-amber-400/60 font-medium">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-400/50 animate-pulse" />
            Demo{activeScenario ? ` · ${activeScenario}` : ''}
          </div>
        )
      }

      <a
        href="/"
        class="inline-flex items-center gap-1.5 text-[9px] text-white/25 hover:text-hielo/50 transition-colors tracking-[0.15em] uppercase font-medium mb-6 group"
      >
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          class="group-hover:-translate-x-0.5 transition-transform"
          ><path d="M19 12H5M12 19l-7-7 7-7"></path></svg
        >
        Volver al Gurú
      </a>

      <div class="mb-6">
        <span
          class="text-[8px] text-hielo/40 tracking-[0.35em] uppercase font-semibold"
          >EL GURÚ LAB</span
        >
        <h1
          class="text-2xl md:text-3xl font-extrabold text-white tracking-[-0.02em] mt-1"
        >
          Los instrumentos con los que miro la montaña.
        </h1>
        <p class="text-[11px] text-white/30 mt-1.5 leading-relaxed max-w-xl">
          Temperatura, cota, viento, humedad y señales de nieve para entender
          por qué el Gurú dice lo que dice.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 mb-5">
        <NowCard
          currentWeather={normalized.currentWeather}
          weatherApi={result.weatherApi ?? undefined}
        />
        <PowderScore
          value={result.powderScore.value}
          reason={result.powderScore.description}
        />
        <SnowWindow
          hasWindow={result.bestWindow.hasWindow}
          from={result.bestWindow.from}
          to={result.bestWindow.to}
          label={result.bestWindow.label}
          description={result.bestWindow.description}
        />
        <AlertsPanel alerts={result.alerts} />
      </div>

      <div class="space-y-4" data-period-group>
        <div
          class="rounded-xl px-4 py-2.5"
          style="background: rgba(9,16,22,0.6); border: 1px solid rgba(255,255,255,0.03);"
        >
          <div class="flex items-center gap-2 mb-2">
            <div
              class="w-1 h-3 bg-gradient-to-b from-white/10 to-white/5 rounded-full"
            >
            </div>
            <span
              class="text-[8px] text-white/20 tracking-[0.22em] uppercase font-medium"
              >LECTURA POR ALTURA</span
            >
            <div class="flex-1 h-[1px] bg-white/[0.03]"></div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            {zoneList.map((zone) => <ZoneCard zone={zone} />)}
          </div>
        </div>

        <ForecastChart
          zoneHourlyToday={zoneHourlyToday}
          zoneHourlyTomorrow={zoneHourlyTomorrow}
          dailySummaries={dailySummaries}
          periods={periods}
        />

        <div
          class="bg-[rgba(9,16,22,0.4)] border border-white/[0.03] rounded-lg px-3 py-2"
        >
          <span
            class="text-[6px] text-white/15 tracking-[0.25em] uppercase font-medium"
            >Interpretación automática</span
          >
          <GuruSummary summary={result.guruSummary} />
        </div>

        {
          normalized.aicHistory && normalized.aicHistory.length > 0 ? (
            <div
              class="bg-[rgba(9,16,22,0.4)] border border-white/[0.03] rounded-lg px-3 py-2"
            >
              <div class="flex items-center gap-2 mb-2">
                <div class="w-1 h-3 bg-gradient-to-b from-white/10 to-white/5 rounded-full"></div>
                <span
                  class="text-[6px] text-white/15 tracking-[0.25em] uppercase font-medium"
                  >Historial AIC</span
                >
              </div>
              <div class="max-h-64 overflow-y-auto">
                <table class="w-full text-[9px]">
                  <thead>
                    <tr class="text-white/25 border-b border-white/[0.03]">
                      <th class="text-left py-1 pr-2 font-medium">Fecha</th>
                      <th class="text-right px-1 font-medium">Precip.</th>
                      <th class="text-right px-1 font-medium">Humedad</th>
                      <th class="text-right px-1 font-medium">T. m&iacute;n</th>
                      <th class="text-right px-1 font-medium">T. m&aacute;x</th>
                      <th class="text-right px-1 font-medium">Viento</th>
                      <th class="text-right pl-1 font-medium">Dir.</th>
                      <th class="text-right pl-1 font-medium">Nieve</th>
                    </tr>
                  </thead>
                  <tbody>
                    {
                      normalized.aicHistory.map((entry) => {
                        const dateStr = entry.date
                          ? new Date(entry.date).toLocaleDateString('es-AR', {
                              day: '2-digit',
                              month: '2-digit',
                            })
                          : '--';
                        const compassDir =
                          entry.windDir != null
                            ? ['N', 'NE', 'E', 'SE', 'S', 'SW', 'W', 'NW'][
                                Math.round(entry.windDir / 45) % 8
                              ]
                            : null;
                        return (
                          <tr class="border-b border-white/[0.01] hover:bg-white/[0.02]">
                            <td class="py-1 pr-2 text-white/70">{dateStr}</td>
                            <td class="text-right px-1 text-white/60 tabular-nums">
                              {entry.precipitation != null
                                ? `${entry.precipitation} mm`
                                : '--'}
                            </td>
                            <td class="text-right px-1 text-white/60 tabular-nums">
                              {entry.humidity != null
                                ? `${entry.humidity}%`
                                : '--'}
                            </td>
                            <td class="text-right px-1 text-white/60 tabular-nums">
                              {entry.tempMin != null
                                ? `${entry.tempMin}\u00b0C`
                                : '--'}
                            </td>
                            <td class="text-right px-1 text-white/60 tabular-nums">
                              {entry.tempMax != null
                                ? `${entry.tempMax}\u00b0C`
                                : '--'}
                            </td>
                            <td class="text-right px-1 text-white/60 tabular-nums">
                              {entry.windSpeed != null
                                ? `${entry.windSpeed} km/h`
                                : '--'}
                            </td>
                            <td class="text-right pl-1 text-white/40 tabular-nums">
                              {compassDir ?? '--'}
                            </td>
                            <td class="text-right pl-1 text-white/60 tabular-nums">
                              {entry.snowWaterEq != null
                                ? `${entry.snowWaterEq} mm`
                                : '--'}
                            </td>
                          </tr>
                        );
                      })
                    }
                  </tbody>
                </table>
              </div>
            </div>
          ) : (
            <div
              class="bg-[rgba(9,16,22,0.4)] border border-white/[0.03] rounded-lg px-3 py-2"
            >
              <div class="flex items-center gap-2 mb-2">
                <div class="w-1 h-3 bg-gradient-to-b from-white/10 to-white/5 rounded-full"></div>
                <span
                  class="text-[6px] text-white/15 tracking-[0.25em] uppercase font-medium"
                  >Historial AIC</span
                >
              </div>
              <p class="text-white/30 text-[10px]">Sin datos hist&oacute;ricos</p>
            </div>
          )
        }
      </div>
    </main>
  </body>
</html>
<div id="period-json" hidden>{periodDataJson}</div>
<script is:inline>
  (function () {
    var data = JSON.parse(document.getElementById('period-json').textContent);
    var PERIODS = data.periods;
    var TOURIST = data.touristCopies;
    var TOURIST_SRC = data.touristSources;
    var TOURIST_MOODS = data.touristMoods;
    var TOURIST_CERTS = data.touristCertainties;
    var TOURIST_TIPS = data.touristTips;
    var PERIOD_DATA = {
      today: {
        heroAnswer: PERIODS.today.mainAnswer,
        powderScore: PERIODS.today.powderScore,
        bestWindow: PERIODS.today.bestWindow,
        alerts: PERIODS.today.alerts,
        guruSummary: PERIODS.today.guruSummary,
        zones: PERIODS.today.zones,
        touristCopy: TOURIST.today,
        touristSource: TOURIST_SRC.today,
        mood: TOURIST_MOODS.today,
        certainty: TOURIST_CERTS.today,
        tip: TOURIST_TIPS.today,
      },
      tomorrow: {
        heroAnswer: PERIODS.tomorrow.mainAnswer,
        powderScore: PERIODS.tomorrow.powderScore,
        bestWindow: PERIODS.tomorrow.bestWindow,
        alerts: PERIODS.tomorrow.alerts,
        guruSummary: PERIODS.tomorrow.guruSummary,
        zones: PERIODS.tomorrow.zones,
        touristCopy: TOURIST.tomorrow,
        touristSource: TOURIST_SRC.tomorrow,
        mood: TOURIST_MOODS.tomorrow,
        certainty: TOURIST_CERTS.tomorrow,
        tip: TOURIST_TIPS.tomorrow,
      },
      sevenDays: {
        heroAnswer: PERIODS.sevenDays.mainAnswer,
        powderScore: PERIODS.sevenDays.powderScore,
        bestWindow: PERIODS.sevenDays.bestWindow,
        alerts: PERIODS.sevenDays.alerts,
        guruSummary: PERIODS.sevenDays.guruSummary,
        zones: PERIODS.sevenDays.zones,
        touristCopy: TOURIST.sevenDays,
        touristSource: TOURIST_SRC.sevenDays,
        mood: TOURIST_MOODS.sevenDays,
        certainty: TOURIST_CERTS.sevenDays,
        tip: TOURIST_TIPS.sevenDays,
      },
    };

    function setActivePeriod(periodKey) {
      var p = PERIOD_DATA[periodKey];
      if (!p) return;

      var heroAnswerEl = document.querySelector('[data-period-hero-answer]');
      if (heroAnswerEl) {
        var answerBadge = heroAnswerEl.querySelector(
          '[data-period-hero-badge]',
        );
        var desc = heroAnswerEl.querySelector('[data-period-hero-desc]');
        if (answerBadge) answerBadge.textContent = p.heroAnswer.label;
        if (desc) desc.textContent = p.heroAnswer.description;
      }

      var powderEl = document.querySelector('[data-period-powder]');
      if (powderEl) {
        var val = powderEl.querySelector('[data-period-powder-val]');
        var reason = powderEl.querySelector('[data-period-powder-reason]');
        if (val) val.textContent = String(p.powderScore.value);
        if (reason) reason.textContent = p.powderScore.description;
      }

      var windowEl = document.querySelector('[data-period-window]');
      if (windowEl) {
        var fromEl = windowEl.querySelector('[data-period-window-from]');
        var toEl = windowEl.querySelector('[data-period-window-to]');
        var descEl = windowEl.querySelector('[data-period-window-desc]');
        var noWindow = windowEl.querySelector('[data-period-window-none]');
        if (p.bestWindow.hasWindow) {
          if (fromEl) {
            fromEl.textContent = p.bestWindow.from || '';
            fromEl.style.display = '';
          }
          if (toEl) {
            toEl.textContent = p.bestWindow.to || '';
            toEl.style.display = '';
          }
          if (descEl) {
            descEl.textContent = p.bestWindow.description;
            descEl.style.display = '';
          }
          if (noWindow) noWindow.style.display = 'none';
        } else {
          if (fromEl) fromEl.style.display = 'none';
          if (toEl) toEl.style.display = 'none';
          if (descEl) descEl.style.display = 'none';
          if (noWindow) noWindow.style.display = '';
        }
      }

      var alertsEl = document.querySelector('[data-period-alerts]');
      if (alertsEl) {
        var items = alertsEl.querySelectorAll('[data-period-alert-item]');
        var noneEl = alertsEl.querySelector('[data-period-alerts-none]');
        var alerts = p.alerts.slice(0, 2);
        items.forEach(function (el, i) {
          if (i < alerts.length) {
            var msg = el.querySelector('[data-period-alert-msg]');
            if (msg) msg.textContent = alerts[i].message;
            el.style.display = '';
          } else {
            el.style.display = 'none';
          }
        });
        if (noneEl) noneEl.style.display = alerts.length === 0 ? '' : 'none';
      }

      var guruEl = document.querySelector('[data-period-guru]');
      if (guruEl) {
        var text = guruEl.querySelector('[data-period-guru-text]');
        if (text) text.textContent = p.guruSummary;
      }

      var touristEl = document.querySelector('[data-period-guru-tourist]');
      if (touristEl) {
        /* Update mood attribute on the container */
        touristEl.setAttribute('data-mood', p.mood || 'neutral');

        /* Update mood dot */
        var moodDot = touristEl.querySelector('[data-mood-indicator]');
        if (moodDot) {
          moodDot.style.background = 'var(--mood-color, #94a3b8)';
        }

        /* Update certainty label */
        var certLabel = touristEl.querySelector('[data-certainty-label]');
        if (certLabel) {
          var labels = { alta: 'Alta', media: 'Media', baja: 'Baja' };
          certLabel.textContent = labels[p.certainty] || p.certainty;
        }

        /* Update tip line */
        var tipLine = touristEl.querySelector('[data-tip-line]');
        if (tipLine) {
          if (p.tip) {
            tipLine.style.display = '';
            tipLine.querySelector('span').textContent = p.tip;
          } else {
            tipLine.style.display = 'none';
          }
        }

        /* Update text content */
        var touristText = touristEl.querySelector(
          '[data-period-guru-tourist-text]',
        );
        if (touristText) touristText.textContent = p.touristCopy;
      }

      var heroSub = document.querySelector('[data-period-hero-subtitle]');
      if (heroSub) {
        var labels = { today: 'Hoy', tomorrow: 'Mañana', sevenDays: '7 días' };
        heroSub.textContent =
          'Pronóstico para ' + (labels[periodKey] || periodKey);
      }

      var tabs = document.querySelectorAll('.period-tab');
      tabs.forEach(function (t) {
        var isActive = t.dataset.period === periodKey;
        t.className = isActive
          ? 'period-tab text-hielo/70 font-semibold bg-hielo/[0.06] px-2 py-0.5 rounded-full'
          : 'period-tab text-white/20 px-1.5 py-0.5';
      });
      var charts = document.querySelectorAll('.period-chart');
      charts.forEach(function (c) {
        c.style.display = c.dataset.period === periodKey ? 'block' : 'none';
      });

      var zoneCards = document.querySelectorAll('[data-period-zone]');
      var zones = p.zones;
      if (zones) {
        var zoneKeys = ['village', 'mid', 'top'];
        zoneCards.forEach(function (card, i) {
          if (i < zoneKeys.length) {
            var z = zones[zoneKeys[i]];
            if (!z) return;
            var tempEl = card.querySelector('[data-period-zone-temp]');
            var feelsEl = card.querySelector('[data-period-zone-feels]');
            var windEl = card.querySelector('[data-period-zone-wind]');
            var snowEl = card.querySelector('[data-period-zone-snow]');
            var answerEl = card.querySelector('[data-period-zone-answer]');
            if (tempEl)
              tempEl.textContent = Math.round(z.current.temp) + '\u00b0';
            if (feelsEl)
              feelsEl.textContent = String(Math.round(z.current.feelsLike));
            if (windEl)
              windEl.textContent = Math.round(z.current.wind) + ' km/h';
            if (snowEl)
              snowEl.textContent = Math.round(z.current.snowChance) + '%';
            var snowDepthEl = card.querySelector(
              '[data-period-zone-snowdepth]',
            );
            if (snowDepthEl && z.current.snowDepth !== undefined) {
              var sd = Math.round(z.current.snowDepth * 100);
              snowDepthEl.textContent =
                sd === 0 ? 'Sin nieve acumulada' : sd + ' cm';
              snowDepthEl.parentElement.style.display = '';
            } else if (snowDepthEl) {
              snowDepthEl.parentElement.style.display = 'none';
            }
            if (answerEl) {
              var ft = z.answer.label;
              if (z.id === 'village' && z.current.precipitation === 0)
                ft = 'Sin precipitación activa';
              else if (z.id === 'top' && z.current.freezingLevel > 2500)
                ft = 'Cota alta para acumulación relevante';
              answerEl.textContent = ft;
            }
          }
        });
      }
    }

    document.addEventListener('click', function (e) {
      var tab = e.target.closest('.period-tab');
      if (tab) {
        var period = tab.dataset.period;
        if (period && PERIOD_DATA[period]) {
          setActivePeriod(period);
        }
      }
    });
  })();
</script>
