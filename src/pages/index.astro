---
import '../styles/tailwind.css';
import type { PeriodKey, PeriodInterpretations } from '../lib/types';
import type { DemoSenario } from '../data/demo-scenarios';
import { getWeatherData, type WeatherMode } from '../lib/weather/weather-source';
import { analyzeAllPeriods } from '../lib/period-engine';
import { isValidScenario } from '../data/demo-scenarios';
import Sidebar from '../components/Sidebar.astro';
import MobileNav from '../components/MobileNav.astro';
import GuruNpcCard from '../components/guru/GuruNpcCard.astro';
import { generateTouristCopy, type GuruCopyInput } from '../lib/ai/guru-copy';

const params = Astro.url.searchParams;
const demoParam = params.get('demo');
const activeScenario: DemoSenario | undefined = isValidScenario(demoParam) ? demoParam : undefined;
const queryMode: WeatherMode | undefined = demoParam === '1' || activeScenario ? 'demo' : undefined;
const envMode: WeatherMode | undefined = process.env.PUBLIC_WEATHER_MODE === 'demo' ? 'demo' : undefined;
const activeMode: WeatherMode = queryMode ?? envMode ?? 'real';

const { data: weather, normalized, weatherApi, source } = await getWeatherData({ mode: activeMode, scenario: activeScenario });
const firstPeriod: PeriodKey = 'today';
const periods = analyzeAllPeriods(normalized);
const result = periods[firstPeriod];
if (weatherApi) result.weatherApi = weatherApi;
const isDemo = source === 'mock-demo';

const periodKeys: PeriodKey[] = ['today', 'tomorrow', 'sevenDays'];
const touristResults = await Promise.all(periodKeys.map(async (key) => {
  const p = periods[key];
  const input: GuruCopyInput = {
    period: key,
    mainAnswer: p.mainAnswer,
    powderScore: p.powderScore,
    bestWindow: p.bestWindow,
    alerts: p.alerts,
    zones: p.zones,
    now: weatherApi ?? undefined
  };
  return generateTouristCopy(input);
}));
const touristCopies: Record<PeriodKey, string> = {} as Record<PeriodKey, string>;
const touristSources: Record<PeriodKey, string> = {} as Record<PeriodKey, string>;
periodKeys.forEach((key, i) => {
  touristCopies[key] = touristResults[i].touristCopy;
  touristSources[key] = touristResults[i].source;
});

const mainCopy = touristCopies.today || 'Hoy no veo nieve, rider. La montaña está fría, pero seca. No te manijees todavía: por ahora es día de encerar la tabla y mirar el cerro de reojo.';

const freez = result.zones.village.current.freezingLevel;
const cotaLabel = freez > 2600 ? 'Cota alta' : freez > 2200 ? 'Cota justa' : 'Cota favorable';
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>El Gurú de la Nieve | Caviahue</title>
    <meta name="description" content="¿Nieva en Caviahue? El Gurú te dice cómo viene la montaña hoy. Lectura humana sin tecnicismos." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://elgurudelanieve.vercel.app/" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/emblema.png" />
    <meta name="theme-color" content="#a8e7f9" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="El Gurú de la Nieve | Caviahue" />
    <meta property="og:description" content="¿Nieva en Caviahue? El Gurú te dice cómo viene la montaña." />
    <meta property="og:url" content="https://elgurudelanieve.vercel.app/" />
    <meta property="og:site_name" content="El Gurú de la Nieve | Caviahue" />
    <meta property="og:image" content="https://elgurudelanieve.vercel.app/og-image-v2.png" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_AR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="El Gurú de la Nieve | Caviahue" />
    <meta name="twitter:description" content="¿Nieva en Caviahue? El Gurú te dice cómo viene la montaña." />
    <meta name="twitter:image" content="https://elgurudelanieve.vercel.app/og-image-v2.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>
  <body class="text-white min-h-screen antialiased font-premium overflow-x-hidden">
    <MobileNav activeSection="home" />
    <div class="flex min-h-screen min-w-0">
      <Sidebar updated={result.updated} source={source} weatherApi={result.weatherApi ?? null} activeSection="home" />
      <main class="flex-1 px-4 md:px-10 py-2 md:py-3 relative pt-12 md:pt-2">

        {isDemo && (
          <div class="absolute top-2 right-0 z-20 flex items-center gap-1 px-2 py-0.5 rounded-full border border-amber-400/20 bg-amber-400/5 text-[7px] tracking-[0.2em] uppercase text-amber-400/60 font-medium">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-400/50 animate-pulse" />
            Demo{activeScenario ? ` · ${activeScenario}` : ''}
          </div>
        )}

        <div class="max-w-xl mx-auto space-y-6">
          <GuruNpcCard
            touristCopy={mainCopy}
            source={touristSources.today || 'fallback'}
            snowLabel={result.snowLabel}
          />

          {result.weatherApi && (
            <div class="flex items-center gap-x-3 gap-y-1.5 text-[10px] text-white/40 px-4 py-2.5 bg-hielo/[0.03] border border-hielo/8 rounded-xl font-medium tracking-wide">
              <span class="text-[8px] text-hielo/30 font-semibold tracking-[0.25em] uppercase shrink-0">NOW</span>
              <span class="text-hielo/20">·</span>
              <span>Temp <span class="text-white/60 tabular-nums">{result.weatherApi.temp}</span>°C</span>
              <span class="text-hielo/20">·</span>
              <span>Sens. <span class="text-white/60 tabular-nums">{result.weatherApi.feelsLike}</span>°</span>
              {result.weatherApi.wind != null && result.weatherApi.wind > 0 && (
                <>
                  <span class="text-hielo/20">·</span>
                  <span>Viento <span class="text-white/60 tabular-nums">{result.weatherApi.wind}</span> km/h</span>
                </>
              )}
              {result.weatherApi.humidity != null && (
                <>
                  <span class="text-hielo/20">·</span>
                  <span>Humedad <span class="text-white/60 tabular-nums">{result.weatherApi.humidity}</span>%</span>
                </>
              )}
              {result.weatherApi.cloudCover != null && (
                <>
                  <span class="text-hielo/20">·</span>
                  <span>Nubosidad <span class="text-white/60 tabular-nums">{result.weatherApi.cloudCover}</span>%</span>
                </>
              )}
              <span class="text-hielo/20">·</span>
              <span>{cotaLabel}</span>
              <span class="text-hielo/20">·</span>
              <span class="text-white/50">Cielo limpio</span>
            </div>
          )}

          <div class="space-y-3">
            <div class="flex items-center gap-2">
              <div class="w-1.5 h-1.5 rounded-full bg-hielo/40"></div>
              <span class="text-[8px] text-white/25 tracking-[0.2em] uppercase font-medium">Lectura del Gurú</span>
            </div>

            <div class="bg-[rgba(9,16,22,0.7)] border border-white/[0.04] rounded-xl px-4 py-3 space-y-2.5">
              <div class="flex items-start gap-3">
                <span class="text-[9px] text-hielo/50 font-semibold w-16 shrink-0 tracking-[0.1em]">HOY</span>
                <p class="text-[11px] text-white/55 leading-relaxed">No veo nieve clara para hoy. Falta humedad.</p>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-[9px] text-hielo/50 font-semibold w-16 shrink-0 tracking-[0.1em]">MAÑANA</span>
                <p class="text-[11px] text-white/55 leading-relaxed">Mañana lo veo parecido: frío hay, pero sin humedad no hay negocio.</p>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-[9px] text-hielo/50 font-semibold w-16 shrink-0 tracking-[0.1em]">ESTA SEMANA</span>
                <p class="text-[11px] text-white/55 leading-relaxed">Más adelante voy a mirar si baja la cota y entra precipitación.</p>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-[9px] text-hielo/50 font-semibold w-16 shrink-0 tracking-[0.1em]">PRÓXIMOS DÍAS</span>
                <p class="text-[11px] text-white/55 leading-relaxed">Si se alinean frío y humedad, puede aparecer una ventana. Quedá atento.</p>
              </div>
            </div>
          </div>

          <div class="pt-2 pb-4">
            <a
              href="/lab"
              class="inline-flex items-center gap-2 text-[9px] text-hielo/40 hover:text-hielo/60 transition-colors tracking-[0.15em] uppercase font-medium border border-hielo/10 hover:border-hielo/20 rounded-full px-4 py-2 bg-hielo/[0.03] hover:bg-hielo/[0.06]"
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M9 3h6M12 3v6M5 21h14M7 21V11M17 21V11M9 11l3 3 3-3M12 14v7"/>
              </svg>
              Abrir El Gurú Lab
            </a>
          </div>
        </div>

      </main>
    </div>
  </body>
</html>