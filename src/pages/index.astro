---
import '../styles/tailwind.css';
import type { PeriodKey, PeriodInterpretations } from '../lib/types';
import type { DemoScenario } from '../data/demo-scenarios';
import {
  getWeatherData,
  type WeatherMode,
} from '../lib/weather/weather-source';
import { analyzeAllPeriods } from '../lib/period-engine';
import { isValidScenario } from '../data/demo-scenarios';
import MobileNav from '../components/MobileNav.astro';
import GuruNpcCard from '../components/guru/GuruNpcCard.astro';
import { generateGuruNpcMessage, type GuruCopyInput } from '../lib/ai/guru-copy';
import type { GuruNpcOutput } from '../lib/ai/types';
import { getSevenDayForecast } from '../lib/forecast-periods';
import HeadMeta from '../components/HeadMeta.astro';
import SchemaOrg from '../components/SchemaOrg.astro';

const params = Astro.url.searchParams;
const demoParam = params.get('demo');
const activeScenario: DemoScenario | undefined = isValidScenario(demoParam)
  ? demoParam
  : undefined;
const queryMode: WeatherMode | undefined =
  demoParam === '1' || activeScenario ? 'demo' : undefined;
const envMode: WeatherMode | undefined =
  process.env.PUBLIC_WEATHER_MODE === 'demo' ? 'demo' : undefined;
const activeMode: WeatherMode = queryMode ?? envMode ?? 'real';

const { normalized, weatherApi, source, sourceStatus } = await getWeatherData({
  mode: activeMode,
  scenario: activeScenario,
});
const firstPeriod: PeriodKey = 'today';
const periods = analyzeAllPeriods(normalized, sourceStatus);
const result = periods[firstPeriod];
if (weatherApi) result.weatherApi = weatherApi;
const isDemo = source === 'mock-demo';

const dailySummaries = getSevenDayForecast(normalized.hourly);
const periodKeys: PeriodKey[] = ['today', 'tomorrow', 'sevenDays'];
const touristResults = await Promise.all(
  periodKeys.map(async (key) => {
    const p = periods[key];
    const input: GuruCopyInput = {
      period: key,
      mainAnswer: p.mainAnswer,
      powderScore: p.powderScore,
      bestWindow: p.bestWindow,
      alerts: p.alerts,
      zones: p.zones,
      now: weatherApi ?? undefined,
      nextDays: dailySummaries,
      aicHistory: normalized.aicHistory,
      narrativeTier: p.narrativeTier,
      resortStatus: p.resortStatus,
    };
    return generateGuruNpcMessage(input);
  }),
);
const touristData: Record<PeriodKey, GuruNpcOutput> = {} as Record<
  PeriodKey,
  GuruNpcOutput
>;
periodKeys.forEach((key, i) => {
  touristData[key] = touristResults[i];
});

const mainCopy =
  touristData.today?.message ||
  'Hoy no veo nieve, rider. La montaña está fría, pero seca. No te manijees todavía: por ahora es día de encerar la tabla y mirar el cerro de reojo.';
const tomorrowCopy =
  touristData.tomorrow?.message ||
  'Mañana lo veo parecido: frío hay, pero sin humedad no hay negocio.';
const weekCopy =
  touristData.sevenDays?.message ||
  'Más adelante voy a mirar si baja la cota y entra precipitación.';

const freez = result.zones.village.current.freezingLevel;
const cotaLabel =
  freez > 2600 ? 'Cota alta' : freez > 2200 ? 'Cota justa' : 'Cota favorable';
---

<html lang="es">
  <head>
    <HeadMeta
      title="El Gurú de la Nieve | Caviahue"
      description="¿Nieva en Caviahue? El Gurú te dice cómo viene la montaña hoy. Lectura humana sin tecnicismos."
      canonicalPath="/"
    />
    <SchemaOrg />
  </head>
  <body
    class="text-white min-h-screen antialiased font-premium overflow-x-hidden"
  >
    <MobileNav activeSection="home" />
    <main class="min-h-screen pt-12 px-4 md:px-8 pb-8">
      {
        isDemo && (
          <div class="absolute top-14 right-4 z-20 flex items-center gap-1 px-2 py-0.5 rounded-full border border-amber-400/20 bg-amber-400/5 text-[7px] tracking-[0.2em] uppercase text-amber-400/60 font-medium">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-400/50 animate-pulse" />
            Demo{activeScenario ? ` · ${activeScenario}` : ''}
          </div>
        )
      }

      <div class="max-w-xl mx-auto space-y-6">
        <GuruNpcCard
          mood={touristData.today?.mood ?? 'neutral'}
          certainty={touristData.today?.certainty ?? 'baja'}
          message={mainCopy}
          tip={touristData.today?.tip ?? null}
          source={touristData.today?.source ?? 'fallback'}
          snowLabel={result.snowLabel}
        />

        {
          (normalized.currentWeather || result.weatherApi) && (
            <div class="flex items-center gap-x-3 gap-y-1.5 text-[10px] text-white/40 px-4 py-2.5 bg-hielo/[0.03] border border-hielo/8 rounded-xl font-medium tracking-wide">
              <span class="text-[8px] text-hielo/30 font-semibold tracking-[0.25em] uppercase shrink-0">
                NOW
              </span>
              <span class="text-hielo/20">·</span>
              <span>
                Temp{' '}
                <span class="text-white/60 tabular-nums">
                  {normalized.currentWeather?.temperature ??
                    result.weatherApi?.temp}
                </span>
                °C
              </span>
              {result.weatherApi?.feelsLike != null && (
                <>
                  <span class="text-hielo/20">·</span>
                  <span>
                    Sens.{' '}
                    <span class="text-white/60 tabular-nums">
                      {result.weatherApi.feelsLike}
                    </span>
                    °
                  </span>
                </>
              )}
              {(() => {
                const windKmh =
                  normalized.currentWeather?.windspeed != null
                    ? Math.round(normalized.currentWeather.windspeed * 3.6)
                    : result.weatherApi?.wind;
                return windKmh != null && windKmh > 0 ? (
                  <>
                    <span class="text-hielo/20">·</span>
                    <span>
                      Viento{' '}
                      <span class="text-white/60 tabular-nums">{windKmh}</span>{' '}
                      km/h
                    </span>
                  </>
                ) : null;
              })()}
              {result.weatherApi?.humidity != null && (
                <>
                  <span class="text-hielo/20">·</span>
                  <span>
                    Humedad{' '}
                    <span class="text-white/60 tabular-nums">
                      {result.weatherApi.humidity}
                    </span>
                    %
                  </span>
                </>
              )}
              {result.weatherApi?.cloudCover != null && (
                <>
                  <span class="text-hielo/20">·</span>
                  <span>
                    Nubosidad{' '}
                    <span class="text-white/60 tabular-nums">
                      {result.weatherApi.cloudCover}
                    </span>
                    %
                  </span>
                </>
              )}
              <span class="text-hielo/20">·</span>
              <span>{cotaLabel}</span>
            </div>
          )
        }

        <div class="space-y-3">
          <div class="flex items-center gap-2">
            <div class="w-1.5 h-1.5 rounded-full bg-hielo/40"></div>
            <span
              class="text-[8px] text-white/25 tracking-[0.2em] uppercase font-medium"
              >Lectura del Gurú</span
            >
          </div>

          <div
            class="bg-[rgba(9,16,22,0.7)] border border-white/[0.04] rounded-xl px-4 py-3 space-y-2.5"
          >
            <div class="flex items-start gap-3">
              <span
                class="text-[9px] text-hielo/50 font-semibold w-16 shrink-0 tracking-[0.1em]"
                >HOY</span
              >
              <p class="text-[11px] text-white/55 leading-relaxed">
                {mainCopy}
              </p>
            </div>
            <div class="flex items-start gap-3">
              <span
                class="text-[9px] text-hielo/50 font-semibold w-16 shrink-0 tracking-[0.1em]"
                >MAÑANA</span
              >
              <p class="text-[11px] text-white/55 leading-relaxed">
                {tomorrowCopy}
              </p>
            </div>
            <div class="flex items-start gap-3">
              <span
                class="text-[9px] text-hielo/50 font-semibold w-16 shrink-0 tracking-[0.1em]"
                >ESTA SEMANA</span
              >
              <p class="text-[11px] text-white/55 leading-relaxed">
                {weekCopy}
              </p>
            </div>
            <div class="flex items-start gap-3">
              <span
                class="text-[9px] text-hielo/50 font-semibold w-16 shrink-0 tracking-[0.1em]"
                >PRÓXIMOS DÍAS</span
              >
              <p class="text-[11px] text-white/55 leading-relaxed">
                Si se alinean frío y humedad, puede aparecer una ventana. Quedá
                atento.
              </p>
            </div>
          </div>
        </div>

        <div class="space-y-3">
          <div class="flex items-center gap-2">
            <div class="w-1.5 h-1.5 rounded-full bg-hielo/40"></div>
            <span
              class="text-[8px] text-white/25 tracking-[0.2em] uppercase font-medium"
              >Preguntas frecuentes</span
            >
          </div>

          <div
            class="bg-[rgba(9,16,22,0.7)] border border-white/[0.04] rounded-xl px-4 py-3 space-y-3"
          >
            <div>
              <h2 class="text-[12px] font-semibold text-white/80 mb-1">
                ¿Va a nevar en Caviahue hoy?
              </h2>
              <p class="text-[11px] text-white/55 leading-relaxed">
                El Gurú lee los modelos meteorológicos para Caviahue y traduce
                la señal de frío, humedad y cota de nieve. {
                  result.mainAnswer.description
                } Esto indica nieve meteorológica en formación, no una
                recomendación de actividad en montaña. Antes de salir, consultá
                el parte oficial del centro.
              </p>
            </div>
            <div>
              <h2 class="text-[12px] font-semibold text-white/80 mb-1">
                ¿Hay nieve en Caviahue hoy?
              </h2>
              <p class="text-[11px] text-white/55 leading-relaxed">
                Hoy el Gurú detecta señal de nieve meteorológica según los
                modelos actuales. Eso describe precipitación sólida esperada,
                no nieve acumulada ni base esquiable en el cerro. Para entender
                cómo se distribuye por cotas, mirá el pronóstico extendido
                desglosado.
              </p>
            </div>
            <div>
              <h2 class="text-[12px] font-semibold text-white/80 mb-1">
                ¿Cuándo puede nevar en Caviahue?
              </h2>
              <p class="text-[11px] text-white/55 leading-relaxed">
                {
                  result.bestWindow.hasWindow
                    ? `La mejor ventana que detecta el Gurú es ${result.bestWindow.label}, entre ${result.bestWindow.from} y ${result.bestWindow.to}. ${result.bestWindow.description} Cuando coinciden frío y humedad, la cota de nieve baja y es más probable la precipitación sólida. Esto no garantiza que el centro esté operativo.`
                    : 'Por ahora no hay una ventana clara. El Gurú la va a marcar cuando se alineen frío y humedad en los próximos días, condición necesaria para que baje la cota de nieve en Caviahue. No implica apertura del centro.'
                }
              </p>
            </div>
            <div>
              <h2 class="text-[12px] font-semibold text-white/80 mb-1">
                ¿En qué altura puede nevar?
              </h2>
              <p class="text-[11px] text-white/55 leading-relaxed">
                La nieve se comporta distinto según la cota. El Gurú desglosa
                el pronóstico para pueblo (1647 m), centro (1846 m) y cumbre
                (2045 m), así se ve en qué altura la precipitación se mantiene
                como nieve y dónde puede cambiar a lluvia por temperatura más
                alta.
              </p>
            </div>
            <div>
              <h2 class="text-[12px] font-semibold text-white/80 mb-1">
                ¿Hay nieve en el pueblo o solo en el cerro?
              </h2>
              <p class="text-[11px] text-white/55 leading-relaxed">
                El pueblo de Caviahue suele tener menos nieve que la base o la
                cumbre del cerro. El pronóstico por cotas muestra dónde la cota
                de nieve permite acumulación y dónde cae como lluvia, pero no
                indica si el centro de ski está operativo.
              </p>
            </div>
            <div>
              <h2 class="text-[12px] font-semibold text-white/80 mb-1">
                ¿Conviene subir al cerro Caviahue hoy?
              </h2>
              <p class="text-[11px] text-white/55 leading-relaxed">
                {
                  result.resortStatus?.seasonStatus === 'open' || result.resortStatus?.seasonStatus === 'partial'
                    ? result.resortStatus?.officialSnowReportAvailable
                      ? 'Hay una ventana meteorológica, pero la decisión de subir depende del parte oficial del centro de ski, del estado de pistas y medios, y de tu propia evaluación. El Gurú lee clima, no reemplaza al parte oficial.'
                      : 'La temporada estaría abierta, pero sin parte oficial de nieve confirmado no podemos hablar de base ni de condiciones esquiables. Consultá el centro antes de subir.'
                    : 'La temporada todavía no está operativa, así que no hay recomendación de subir a esquiar. Podés consultar el pronóstico para entender la nieve meteorológica, pero la decisión de subir depende del parte oficial cuando abra el centro y de tu propia evaluación.'
                }
              </p>
            </div>
            <div>
              <h2 class="text-[12px] font-semibold text-white/80 mb-1">
                ¿Qué fuentes usa El Gurú de la Nieve?
              </h2>
              <p class="text-[11px] text-white/55 leading-relaxed">
                Usa Open-Meteo como pronóstico principal, WeatherAPI.com para la
                condición actual y datos de estaciones AIC para validación
                local. Además, contrasta señales con herramientas como Windguru
                y Snow Forecast para dar una lectura local del clima, siempre
                como interpretación y nunca como reemplazo de los partes
                oficiales.
              </p>
            </div>
            <div>
              <h2 class="text-[12px] font-semibold text-white/80 mb-1">
                ¿Qué tan confiable es el pronóstico?
              </h2>
              <p class="text-[11px] text-white/55 leading-relaxed">
                El Gurú interpreta modelos meteorológicos públicos, no emite
                partes oficiales. La confianza depende de la estabilidad de los
                modelos, de la validación con datos locales y de cómo evolucionen
                las condiciones en la montaña. Antes de salir, consultá fuentes
                oficiales y el parte del centro de ski.
              </p>
            </div>
          </div>
        </div>

        <div class="pt-2 pb-4">
          <a
            href="/lab"
            class="inline-flex items-center gap-2 text-[9px] text-hielo/40 hover:text-hielo/60 transition-colors tracking-[0.15em] uppercase font-medium border border-hielo/10 hover:border-hielo/20 rounded-full px-4 py-2 bg-hielo/[0.03] hover:bg-hielo/[0.06]"
          >
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                d="M9 3h6M12 3v6M5 21h14M7 21V11M17 21V11M9 11l3 3 3-3M12 14v7"
              ></path>
            </svg>
            Abrir El Gurú Lab
          </a>
        </div>
      </div>
    </main>
  </body>
</html>
