---
import '../styles/tailwind.css';
import MobileNav from '../components/MobileNav.astro';
import HistoricoView from '../components/HistoricoView.astro';
import HeadMeta from '../components/HeadMeta.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
---

<html lang="es">
  <head>
    <HeadMeta
      title="Histórico | El Gurú de la Nieve"
      description="Histórico de condiciones de nieve en Caviahue. Lecturas pasadas del Gurú y datos de estaciones AIC."
      canonicalPath="/historico"
    />
    <SchemaOrg />
  </head>
  <body
    class="text-white min-h-screen antialiased font-premium overflow-x-hidden"
  >
    <MobileNav activeSection="historico" />
    <main class="min-h-screen pt-12 px-4 md:px-8 pb-8">
      <div class="max-w-2xl mx-auto">
        <div class="mb-8">
          <h1 class="text-[28px] font-extrabold text-white tracking-tight">
            Histórico
          </h1>
          <p class="text-white/30 text-[11px] mt-1">
            Lecturas pasadas del Gurú · Archivo por fecha
          </p>
        </div>

        <HistoricoView />
      </div>
    </main>
  </body>
</html>
