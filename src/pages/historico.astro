---
import '../styles/tailwind.css';
import MobileNav from '../components/MobileNav.astro';
import HistoricoView from '../components/HistoricoView.astro';
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Histórico | El Gurú de la Nieve</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/emblema.png" />
    <meta name="theme-color" content="#a8e7f9" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme');
        if (t === 'light') document.documentElement.setAttribute('data-theme', 'light');
      })();
    </script>
  </head>
  <body
    class="text-text-primary min-h-screen antialiased font-premium overflow-x-hidden transition-colors duration-300"
  >
    <MobileNav activeSection="historico" />
    <main class="min-h-screen pt-12 px-4 md:px-8 pb-8">
      <div class="max-w-2xl mx-auto">
        <div class="mb-8">
          <h1 class="text-[28px] font-extrabold text-text-primary tracking-tight">
            Histórico
          </h1>
          <p class="text-text-muted text-[11px] mt-1">
            Lecturas pasadas del Gurú · Archivo por fecha
          </p>
        </div>

        <HistoricoView />
      </div>
    </main>
  </body>
</html>
